# Tutte le chiavi sono OPZIONALI: se mancano, l'adapter relativo si disattiva
# e il sistema gira lo stesso con le altre fonti. Budget zero by design.

# --- Base gratis e ufficiale (consigliate) ---
# Ticketmaster Discovery (~5000 call/giorno free). Tour internazionali/grandi eventi.
TICKETMASTER_KEY=

# Spotify Web API (Client Credentials) — NON fonte eventi, solo segnale ranking.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Copertura italiana: girano TUTTE le fonti configurate insieme ---
# Senza override, usa SerpApi (se SERPAPI_KEY) + scraper + Resident Advisor.
# EVENT_SOURCE_IT forza UNA sola fonte IT (debug): scraper | serpapi.
EVENT_SOURCE_IT=

# SerpApi google_events (free ~100-250 ricerche/mese, cache 1x/giorno).
SERPAPI_KEY=

# Resident Advisor (nightlife): nessuna chiave. Metti 0 per disattivarlo.
RA_ENABLED=

# --- Opzionale (Fase 2) ---
# Se presente, il Local Rank di PredictHQ fa override/blend dell'hypeScore.
PREDICTHQ_TOKEN=

# --- Cache ---
# TTL default risposte fonti in secondi (default 21600 = 6h).
# La fonte italiana usa comunque 24h per restare nei limiti gratuiti.
CACHE_TTL_SECONDS=21600

# --- App mobile (Capacitor) ---
# URL del backend Vercel che l'app chiama (NON usato dal sito web).
NEXT_PUBLIC_API_BASE=
